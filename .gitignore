*.blend2
*.blend3
*.blend4
*.blend5

# Mono-specific ignores (nếu sau này bạn dùng bản Godot C#)
.mono/
data_*/
mono_crash.*.json

# Editor / System specific ignores
.DS_Store
.directory
.vscode/
.idea/
*.log
